{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Host=localhost;Port=5433;Database=odisea;Username=odisea;Password=odisea"
  },
  "Jwt": {
    "Issuer": "odisea-api",
    "Audience": "odisea-client",
    "AccessTokenExpiryMinutes": 15
  },
  "Cors": {
    "PortalOrigins": []
  },
  "Swagger": {
    "Enabled": false
  },
  "Seed": {
    "Demo": false
  },
  "ConnectorScheduler": {
    "Enabled": true,
    "PollIntervalSeconds": 300,
    "SyncIntervalMinutes": 360
  }
}
